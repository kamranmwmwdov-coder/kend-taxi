# Supabase layihəndən götür: Project Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# İstənilən uzun, təsadüfi mətn (JWT imzalamaq üçün) - internetdə "random string generator" axtar
JWT_SECRET=change-this-to-a-long-random-string

# Admin-in "Sürücü olmaq istəyirəm" düyməsi üçün WhatsApp nömrəsi (994 ilə, + işarəsiz)
NEXT_PUBLIC_WHATSAPP_ADMIN=994501234567

# Email ilə şifrə bərpası üçün (Resend: resend.com -> API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL="Kənd Taxi <no-reply@sizin-domain.com>"

# Bərpa linkinin düzgün ünvana işarə etməsi üçün saytın əsas ünvanı
NEXT_PUBLIC_APP_URL=https://sizin-domain.com
